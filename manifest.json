{
    "manifest_version": 3,
    "name": "NPTEL Companion: Dark Mode & Mock Quiz",
    "version": "1.0",
    "description": "Enhance your NPTEL experience with a sleek dark theme and interactive mock quizzes for effortless revision and better learning. 🌙📝",
    "permissions": [
        "storage",
        "tabs",
        "activeTab",
        "scripting"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://onlinecourses.nptel.ac.in/*/unit?unit=*&assessment=*",
                "https://onlinecourses.nptel.ac.in/*/unit?unit=*&lesson=*"
            ],
            "js": [
                "toggleTheme.js",
                "generateQuiz.js"
            ],
            "css": [
                "styles.css"
            ]
        }
    ],
    "action": {
        "default_popup": "popup.html"
    }
}